# .env.local.example
# Copy to .env.local and fill in your values.

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-api-key-here

# ── Optional: proxy or alternate endpoint ─────────────────────────────────────
# If using a gateway/proxy, change CLAUDE_API_URL in lib/claude.ts
# CLAUDE_API_URL=https://your-proxy.example.com/v1/messages

# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (email notifications) ───────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
# 1. Add & verify your domain at resend.com/domains
# 2. Create an API key at resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# ── Internal notify secret ─────────────────────────────────────────────────────
# Random string used to authenticate internal API calls to /api/notify
# Generate one: openssl rand -hex 32
NOTIFY_SECRET=your-random-secret-here

# ── Site URL (used for internal API calls) ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://usescheduleme.vercel.app
